# TELEGRAM BOT CONFIGURATION FOR BOTHOST
# ==========================================

# 🤖 TELEGRAM BOT TOKEN
# Get from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# 👮 ADMIN TELEGRAM IDS (comma-separated)
# Example: 123456789,987654321
ADMIN_IDS=123456789

# 🗄️ DATABASE CONFIGURATION
# Format: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/it_market_bot

# 🌐 BOTHOST WEBHOOK CONFIGURATION
# Set to 'true' for production (webhook mode)
# Set to 'false' for local development (polling mode)
USE_WEBHOOK=false
WEBHOOK_URL=https://your-domain.com/webhook

# 💳 OPTIONAL: PAYMENT API KEYS
PAYMENT_API_KEY=your_payment_api_key
